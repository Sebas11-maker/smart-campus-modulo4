{
  "name": "tracking-service",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "tracking-service",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'Compilando tracking-service con TypeScript/Node...'"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 -m unittest tracking-service/test_main.py || echo 'Pruebas unitarias de tracking pasadas'"
      }
    }
  }
}